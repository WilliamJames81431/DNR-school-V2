rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserRole() == 'student';
    }

    function isParent() {
      return isAuthenticated() && getUserRole() == 'parent';
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    // ─── User Profiles ──────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile; staff can read all
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isStaff());
      // Only admins can create/update/delete user profiles
      allow write: if isAdmin();
    }

    // ─── Notices / Announcements ────────────────────────────────────
    match /notices/{noticeId} {
      // Everyone authenticated can read notices
      allow read: if isAuthenticated();
      // Only staff can create/update/delete notices
      allow write: if isStaff();
    }

    // ─── Assignments ────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      // Authenticated users can read assignments
      allow read: if isAuthenticated();
      // Only teachers and admins can manage assignments
      allow write: if isStaff();
    }

    // ─── Attendance ─────────────────────────────────────────────────
    match /attendance/{recordId} {
      // Students/parents can read their own; staff can read all
      allow read: if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isStaff());
      // Only staff can write attendance records
      allow write: if isStaff();
    }

    // ─── Marks / Grades ─────────────────────────────────────────────
    match /marks/{markId} {
      // Students/parents can read their own; staff can read all
      allow read: if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isStaff());
      // Only staff can write marks
      allow write: if isStaff();
    }

    // ─── Messages (Private) ────────────────────────────────────────
    match /messages/{messageId} {
      // Only sender or receiver can read
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
      // Authenticated users can send messages (senderId must match)
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      // Only sender can update/delete their own messages
      allow update, delete: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid;
    }

    // ─── Gallery ────────────────────────────────────────────────────
    match /gallery/{photoId} {
      allow read: if true;  // Public gallery
      allow write: if isAdmin();
    }

    // ─── ATL Projects ───────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if true;  // Public project showcase
      allow write: if isAdmin();
    }

    // ─── Faculty ────────────────────────────────────────────────────
    match /faculty/{facultyId} {
      allow read: if true;  // Public faculty directory
      allow write: if isAdmin();
    }

    // ─── Activities / Events ────────────────────────────────────────
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // ─── Catch-all: deny everything else ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
